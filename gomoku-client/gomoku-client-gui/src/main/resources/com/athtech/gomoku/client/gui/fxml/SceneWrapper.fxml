<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="3000" prefWidth="849.0" spacing="0" stylesheets="@../css/Gomoku.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.athtech.gomoku.client.gui.controllers.WrapperController">

    <!-- Persistent header -->
    <HBox fx:id="headerBar" prefHeight="130.0" prefWidth="723.0" spacing="130.0">
        <Label fx:id="lblConnection" text="🔌" />
        <Label fx:id="lblUsername" text="🔑 LoggedInAs: " />
        <Label fx:id="lblError" text="" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblClock" text="⏰ 00:00:00">
         <HBox.margin>
            <Insets left="120.0" />
         </HBox.margin></Label>
        <Region HBox.hgrow="ALWAYS" />
        <Region HBox.hgrow="ALWAYS" />
        <Button alignment="CENTER" contentDisplay="CENTER" onAction="#handleExit" pickOnBounds="true" style="-fx-background-color: transparent; -fx-text-fill: white;" styleClass="exit-icon" text="EXIT ➜]  " textAlignment="CENTER" textFill="WHITE">
         <font>
            <Font name="High Tower Text Italic" size="14.0" />
         </font></Button>

    </HBox>

    <!-- This container swaps the actual content -->
    <StackPane fx:id="contentPane" />
</VBox>
