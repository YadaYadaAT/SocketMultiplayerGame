<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="3000" prefWidth="1920" spacing="15" styleClass="root-pane" stylesheets="@../css/Singup.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.athtech.gomoku.client.gui.controllers.SignupController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label styleClass="header-label" text="Sign Up" />

    <TextField fx:id="txtSignupUser" promptText="Username" styleClass="input-field" />
    <PasswordField fx:id="txtSignupPwd" promptText="Password" styleClass="input-field" />
    <TextField fx:id="txtSignupNickname" promptText="Nickname" styleClass="input-field" />

    <Label fx:id="serverSignupResponseMessage" styleClass="response-label" />

    <Button fx:id="btnSignup" onAction="#handleSignup" styleClass="primary-button" text="Sign Up">
      <cursor>
         <Cursor fx:constant="OPEN_HAND" />
      </cursor></Button>
    <Button fx:id="btnSwitchLogin" onAction="#handleSwitchLogin" styleClass="secondary-button" text="Back to Login">
      <cursor>
         <Cursor fx:constant="OPEN_HAND" />
      </cursor></Button>
</VBox>
