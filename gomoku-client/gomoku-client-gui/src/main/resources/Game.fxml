<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.athtech.gomoku.client.gui.GameController"
      spacing="10" alignment="CENTER" prefWidth="600" prefHeight="500">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <TextArea fx:id="gameBoardArea" editable="false" prefHeight="300"/>
    <TextArea fx:id="chatArea" editable="false" prefHeight="100"/>
    <TextField fx:id="moveInput" promptText="row,col (or 'q' to quit)"/>
    <Button fx:id="btnSendMove" text="Send Move" onAction="#sendMove"/>
    <Button fx:id="btnQuit" text="Quit" onAction="#quitGame"/>
</VBox>
