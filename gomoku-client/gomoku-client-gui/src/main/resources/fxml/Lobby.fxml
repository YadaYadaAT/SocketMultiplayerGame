<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.athtech.gomoku.client.gui.controllers.LobbyController"
      spacing="10"
      alignment="CENTER"
      prefWidth="700"
      prefHeight="500">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Header -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label text="Lobby || "/>
        <Label text="Played: "/>
        <Label fx:id="played"/>
        <Label text="Wins: "/>
        <Label fx:id="wins"/>
        <Label text="Loses: "/>
        <Label fx:id="loses"/>
        <Label text="Draws: "/>
        <Label fx:id="draws"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"/>
    </HBox>

    <Separator/>

    <!-- Players + Invites -->
    <HBox spacing="10">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Available Players"/>
            <ListView fx:id="lobbyPlayersList" prefHeight="200"/>
            <Button text="Invite Selected Player" onAction="#handleInvite"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Incoming Invites"/>
            <ListView fx:id="inviteListView" prefHeight="200"/>
            <HBox spacing="5">
                <Button text="Accept" onAction="#handleAcceptSelectedInvite"/>
                <Button text="Decline" onAction="#handleDeclineSelectedInvite"/>
            </HBox>
        </VBox>
    </HBox>

    <Separator/>

    <!-- Chat Section (THIS is the growing area) -->
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="Lobby Chat"/>
        <ListView fx:id="chatListView"
                  VBox.vgrow="ALWAYS"
                  maxHeight="Infinity"/>
        <HBox spacing="5">
            <TextField fx:id="chatInput"
                       HBox.hgrow="ALWAYS"
                       promptText="Type message..."/>
            <Button text="Send" onAction="#sendChatMessage"/>
        </HBox>
    </VBox>

    <Separator/>

    <!-- Status -->
    <Label fx:id="lobbyStatusLabel"/>

    <!-- Outgoing invite feedback -->
    <Label fx:id="outgoingInviteLabel"/>

</VBox>
