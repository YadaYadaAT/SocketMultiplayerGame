<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.athtech.gomoku.client.gui.controllers.LobbyController"
      spacing="10"
      alignment="CENTER"
      prefWidth="600"
      prefHeight="400">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Header -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label text="Lobby || "/>
        <Label text="Played: "/>
        <Label fx:id="played" text=""/>
        <Label text="Wins: "/>
        <Label fx:id="wins" text=""/>
        <Label text="Loses: "/>
        <Label fx:id="loses" text=""/>
        <Label text="Draws: "/>
        <Label fx:id="draws" text=""/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"/>
    </HBox>

    <Separator/>

    <!-- Lobby players -->
    <Label text="Available Players"/>
    <ListView fx:id="lobbyPlayersList" prefHeight="200"/>
    <Button text="Invite Selected Player" onAction="#handleInvite"/>

    <!-- Incoming Invites -->
    <VBox spacing="5">
        <Label text="Incoming Invites:"/>
        <ListView fx:id="inviteListView" prefHeight="100"/>
        <HBox spacing="10">
            <Button text="Accept" onAction="#handleAcceptSelectedInvite"/>
            <Button text="Decline" onAction="#handleDeclineSelectedInvite"/>
        </HBox>
    </VBox>

    <Separator/>

    <!-- Status -->
    <Label fx:id="lobbyStatusLabel"/>

</VBox>
