<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800"
            prefWidth="1200"
            styleClass="root-pane"
            stylesheets="@../css/game.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.athtech.gomoku.client.gui.controllers.GameController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER"
              prefHeight="110"
              styleClass="top-bar">
            <Label fx:id="lblGameStatus"
                   styleClass="game-status"
                   textAlignment="CENTER">
                <font>
                    <Font size="16"/>
                </font>
            </Label>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <HBox alignment="CENTER"
              spacing="50"
              styleClass="center-container">

            <VBox fx:id="boardContainer"
                  alignment="CENTER"
                  minWidth="480"
                  minHeight="480"
                  spacing="5"/>

            <Label fx:id="lblTurnInfo"
                   styleClass="turn-info"/>
        </HBox>
    </center>

    <!-- RIGHT PANEL -->
    <right>
        <VBox alignment="CENTER"
              spacing="25"
              styleClass="right-panel"
              BorderPane.alignment="CENTER">

            <!-- MIDGAME -->
            <VBox alignment="CENTER" spacing="15">
                <ToggleButton fx:id="btnMidgameRematch"
                              onAction="#onMidgameRematchToggle"
                              styleClass="rematch-circle"
                              text="↻"/>
                <Button fx:id="btnQuitGame"
                        onAction="#quitGame"
                        styleClass="quit-button"
                        text="Quit Game"/>
            </VBox>

            <!-- ENDGAME -->
            <VBox fx:id="endgameBox"
                  alignment="CENTER"
                  spacing="15"
                  visible="false"
                  managed="false"
                  maxWidth="220"
                  styleClass="endgame-box">

                <Label text="Play again?"
                       styleClass="rematch-label"/>

                <HBox alignment="CENTER" spacing="15">
                    <Button text="Yes"
                            onAction="#onEndGameRematchYes"
                            styleClass="rematch-yes"/>
                    <Button text="No"
                            onAction="#onEndGameRematchNo"
                            styleClass="rematch-no"/>
                </HBox>

                <Button fx:id="btnBackToLobby"
                        onAction="#backToLobby"
                        styleClass="quit-button"
                        text="Back to Lobby"/>
            </VBox>

        </VBox>
    </right>

    <bottom>
        <VBox prefHeight="80">
            <padding>
                <Insets top="10"/>
            </padding>
        </VBox>
    </bottom>

</BorderPane>
