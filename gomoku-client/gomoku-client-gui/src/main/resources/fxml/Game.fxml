<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/Gomoku.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.athtech.gomoku.client.gui.controllers.GameController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>

            <Button onAction="#quitGame" styleClass="quit-button" text="Quit Game"/>

            <Label fx:id="lblGameStatus" styleClass="game-status" text="Game starting..."/>
        </HBox>
    </top>

    <!-- CENTER GAME AREA -->
    <center>
        <HBox alignment="CENTER" spacing="40">

            <!-- BOARD CONTAINER -->
            <VBox fx:id="boardContainer" alignment="CENTER" spacing="2"
                  minHeight="400" minWidth="400" HBox.hgrow="ALWAYS">
                <!-- BoardView will be dynamically added here -->
            </VBox>

            <!-- MIDGAME REMATCH -->
            <VBox alignment="CENTER">
                <ToggleButton fx:id="btnMidgameRematch"
                              onAction="#onMidgameRematchToggle"
                              styleClass="rematch-circle"
                              text="↻"/>
            </VBox>

        </HBox>
    </center>

    <!-- BOTTOM: turn info + end-game rematch -->
    <bottom>
        <VBox alignment="CENTER" spacing="6">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>

            <Label fx:id="lblTurnInfo" styleClass="turn-info" text=""/>

            <HBox fx:id="endGameRematchBox" alignment="CENTER" managed="false" spacing="12" visible="false">
                <Label styleClass="rematch-label" text="Play again?"/>
                <Button onAction="#onEndGameRematchYes" styleClass="rematch-yes" text="Yes"/>
                <Button onAction="#onEndGameRematchNo" styleClass="rematch-no" text="No"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
