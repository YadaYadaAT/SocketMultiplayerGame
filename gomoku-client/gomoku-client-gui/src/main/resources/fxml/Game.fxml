<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800" prefWidth="1200" styleClass="root-pane"
            stylesheets="@../css/game.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.athtech.gomoku.client.gui.controllers.GameController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER" prefHeight="118.0" prefWidth="1200.0" styleClass="top-bar">
            <Label fx:id="lblGameStatus" alignment="CENTER" contentDisplay="CENTER"
                   prefHeight="112.0" prefWidth="1170.0" styleClass="game-status"
                   text="Game starting..." textAlignment="CENTER">
                <font>
                    <Font name="High Tower Text" size="14.0" />
                </font>
            </Label>
        </HBox>
    </top>

    <!-- CENTER GAME AREA -->
    <center>
        <HBox alignment="CENTER" prefHeight="631.0" prefWidth="1021.0" spacing="50" styleClass="center-container">
            <!-- BOARD CONTAINER -->
            <VBox fx:id="boardContainer" alignment="CENTER" minHeight="480" minWidth="480" prefHeight="665.0" prefWidth="1024.0" spacing="5">
                <!-- BoardView will be dynamically added here -->
            </VBox>
        </HBox>
    </center>

    <!-- RIGHT PANEL: midgame / endgame swap -->
    <right>
        <VBox alignment="CENTER" spacing="15" BorderPane.alignment="CENTER">

            <!-- MIDGAME SECTION -->
            <VBox fx:id="midgameBox" alignment="CENTER" spacing="15">
                <Label fx:id="lblTurnInfo" styleClass="turn-info" text="" />
                <ToggleButton fx:id="btnMidgameRematch" onAction="#onMidgameRematchToggle" styleClass="rematch-circle" text="↻" />
                <Button fx:id="btnQuitGame" onAction="#quitGame" styleClass="quit-button" text="Quit Game" />
            </VBox>

            <!-- ENDGAME SECTION -->
            <VBox fx:id="endgameBox" alignment="CENTER" spacing="15" visible="false" managed="false">
                <Label styleClass="rematch-label" text="Play again?" />
                <HBox spacing="15" alignment="CENTER">
                    <Button onAction="#onEndGameRematchYes" styleClass="rematch-yes" text="Yes" />
                    <Button onAction="#onEndGameRematchNo" styleClass="rematch-no" text="No" />
                </HBox>
                <Button fx:id="btnBackToLobby" onAction="#backToLobby" styleClass="quit-button" text="Back to Lobby" />
            </VBox>

        </VBox>
    </right>

    <!-- BOTTOM: padding / spacing -->
    <bottom>
        <VBox alignment="CENTER" prefHeight="112.0" prefWidth="1200.0" spacing="8" styleClass="bottom-bar">
            <padding>
                <Insets bottom="15" left="15" right="15" top="10" />
            </padding>
        </VBox>
    </bottom>

</BorderPane>
